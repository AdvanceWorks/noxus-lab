# Template. Commit this file. Copy to .env (gitignored) and fill in.
NOXUS_API_KEY=your_key_here
NOXUS_BACKEND_URL=https://backend.noxus.ai

# --- Optional: production hardening (all unset by default) ---

# Pluggable secret resolver: any shell command that prints the API key
# to stdout. Overrides .env. Examples:
#   NOXUSLAB_SECRETS_CMD=aws secretsmanager get-secret-value --query SecretString --output text --secret-id noxus/prod
#   NOXUSLAB_SECRETS_CMD=az keyvault secret show --vault-name vlt --name noxus-key --query value -o tsv
#   NOXUSLAB_SECRETS_CMD=op read op://vault/noxus/api_key

# Structured audit log (one JSON line per CLI invocation). Pick one:
# NOXUSLAB_AUDIT_LOG=/var/log/noxuslab/audit.log
# NOXUSLAB_AUDIT=stderr

# Retry/backoff tuning for the Noxus API client.
# NOXUSLAB_MAX_RETRIES=3
# NOXUSLAB_BASE_DELAY=0.5
# NOXUSLAB_MAX_DELAY=8.0
