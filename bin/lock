#!/bin/sh
# Regenerate dependency lock files from pyproject.toml.
# Run after editing dependencies. Commit the resulting .lock files.
set -eu

if [ -x .venv/bin/python ]; then
	vpy=.venv/bin/python
else
	vpy=.venv/Scripts/python.exe
fi

"$vpy" -m pip install --quiet pip-tools
"$vpy" -m piptools compile --quiet --generate-hashes \
	--output-file=requirements.lock pyproject.toml
"$vpy" -m piptools compile --quiet --generate-hashes --extra=dev \
	--output-file=requirements-dev.lock pyproject.toml

echo "ok. requirements.lock and requirements-dev.lock regenerated."
