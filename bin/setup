#!/bin/sh
# Bootstrap: create .venv, install deps, wire git hooks, seed .env.
# Idempotent. Works on Linux, macOS, and Git Bash on Windows.
# Override Python: PYTHON=python3.12 sh bin/setup
set -eu

py=${PYTHON:-}
if [ -z "$py" ]; then
	for cand in python3 python; do
		if "$cand" -V >/dev/null 2>&1; then py=$cand; break; fi
	done
fi
[ -n "$py" ] || { echo "no working python found; set PYTHON=..." >&2; exit 1; }

# Refuse Python below 3.10 — pyproject demands it.
"$py" -c 'import sys; sys.exit(0 if sys.version_info[:2] >= (3,10) else 1)' \
	|| { echo "need Python >= 3.10 (got $($py -V 2>&1))" >&2; exit 1; }

[ -d .venv ] || "$py" -m venv .venv

if [ -x .venv/bin/python ]; then
	vpy=.venv/bin/python
	vbin=.venv/bin
else
	vpy=.venv/Scripts/python.exe
	vbin=.venv/Scripts
fi

"$vpy" -m pip install --upgrade --quiet pip
# Use the lock file when LOCKED=1 (production / CI). Otherwise install
# from pyproject for fast iteration during dev.
if [ "${LOCKED:-0}" = "1" ] && [ -f requirements-dev.lock ]; then
	"$vpy" -m pip install --quiet --require-hashes -r requirements-dev.lock
	"$vpy" -m pip install --quiet --no-deps -e .
else
	"$vpy" -m pip install --quiet -e ".[dev]"
fi

# Wire git hooks so contributors run the same checks CI does.
if [ -d .git ]; then
	if [ -x "$vbin/pre-commit" ] || [ -x "$vbin/pre-commit.exe" ]; then
		"$vpy" -m pre_commit install --install-hooks >/dev/null 2>&1 || true
		"$vpy" -m pre_commit install --hook-type pre-push >/dev/null 2>&1 || true
	fi
fi

[ -f .env ] || cp .env.example .env

echo "ok. edit .env and set NOXUS_API_KEY."
