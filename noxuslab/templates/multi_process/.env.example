# Template. Commit this file. Copy to .env (gitignored) and fill in.

# --- Noxus platform ---
NOXUS_API_KEY=your_noxus_api_key_here
NOXUS_BACKEND_URL=https://backend.noxus.ai

# --- Azure OpenAI (for classification + OCR) ---
# Get these from the Azure portal: AI Foundry -> your resource -> Keys & Endpoint.
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview
