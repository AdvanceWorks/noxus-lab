# Template. Commit this file. Copy to .env (gitignored) and fill in.

# --- Noxus platform ---
NOXUS_API_KEY=your_noxus_api_key_here
NOXUS_BACKEND_URL=https://api.app.noxus.ai

# --- OpenAI (only if your in-platform classifier needs token logprobs) ---
# The Noxus CategorizerNode does not expose token logprobs, so a
# threshold-driven classifier inside a workflow has to call OpenAI (or
# Azure OpenAI) directly via a CodeExecutionV3Node. Store this same
# key as a workspace secret in the Noxus UI under the same name; the
# CLI scripts themselves do not need it.
OPENAI_API_KEY=sk-your_openai_key_here

# --- Azure OpenAI (offline classifier path; optional) ---
# Used by `python -m <workspace>.classifier` to mirror the production
# call without going through the Noxus runtime. Leave blank if you
# only run in-platform.
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview
